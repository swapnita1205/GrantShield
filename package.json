{
  "name": "grantshield",
  "version": "0.1.0",
  "description": "Federal grant portfolio risk dashboard and investigation UI (Next.js, Supabase).",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:populate": "tsx --conditions=react-server --env-file=.env.local scripts/populate.ts",
