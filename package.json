    "db:check": "tsx --conditions=react-server --env-file=.env.local scripts/check-supabase.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "next": "^14.2.18",
    "react": "^18.2.0",
